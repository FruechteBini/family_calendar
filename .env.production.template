# --- Datenbank ---
POSTGRES_USER=kalender
POSTGRES_PASSWORD=HIER_SICHERES_PASSWORT_SETZEN
POSTGRES_DB=kalender

# --- Auth / JWT ---
# Generiere mit: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=HIER_ZUFAELLIGEN_KEY_GENERIEREN
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# --- CORS ---
# Deine Synology-DDNS-Domain (und optional lokale Adressen fuer Entwicklung)
CORS_ORIGINS=https://DEIN-NAME.synology.me,http://localhost:8000

# --- Cookidoo (Thermomix) ---
COOKIDOO_EMAIL=
COOKIDOO_PASSWORD=

# --- Knuspr ---
KNUSPR_EMAIL=
KNUSPR_PASSWORD=

# --- Anthropic (KI-Essensplanung) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
