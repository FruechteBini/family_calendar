# Kopiere nach backend/.env und trage echte Werte ein.
# (.env ist gitignored)

SECRET_KEY=change-me-to-a-random-secret-key
DATABASE_URL=postgresql+asyncpg://kalender:kalender@localhost:5432/kalender
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# Google Login + Calendar/Tasks Sync (Google Cloud → APIs & Dienste → Anmeldedaten → OAuth-Client „Webanwendung“)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Zusätzlich für Android-App: OAuth-Client Typ „Android“ im GLEICHEN Projekt (Paketname z. B. com.example.familienkalender + SHA-1 Debug-Keystore),
# sonst Google Sign-In ApiException 10 (DEVELOPER_ERROR). Skript: flutter/scripts/print_android_debug_sha1.ps1
# Token-Tausch (serverAuthCode): redirect_uri muss in der Cloud Console beim Web-Client eingetragen sein.
# Google erlaubt dort nur http(s), NICHT „postmessage“. Empfehlung:
#   Console → autorisierte Weiterleitungs-URIs: http://localhost
#   .env: GOOGLE_REDIRECT_URI=http://localhost
# Leer lassen → Backend probiert nacheinander "", http://localhost, http://127.0.0.1
GOOGLE_REDIRECT_URI=

# Optional: Push
# FIREBASE_CREDENTIALS_PATH=
# FIREBASE_CREDENTIALS_JSON=
